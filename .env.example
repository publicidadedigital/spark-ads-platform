# Supabase public client config
APP_SUPABASE_URL=
APP_SUPABASE_ANON_KEY=

# Supabase server-only service role key
APP_SUPABASE_SERVICE_ROLE_KEY=

# Public app URL used to build email links in production
# Example: https://spark-ads-platform.vercel.app
APP_PUBLIC_URL=

# Resend email confirmation
# Create the key at https://resend.com/api-keys and paste it in Vercel later.
RESEND_API_KEY=
# Example: Viral Hub <noreply@yourdomain.com>
RESEND_FROM_EMAIL=

# Payment webhook placeholder
PAYMENTS_WEBHOOK_SECRET=

# Cakto payment gateway
# API token used to call the Cakto API when creating checkout sessions.
CAKTO_API_TOKEN=
# Endpoint used to create a checkout session via the Cakto API.
CAKTO_CREATE_CHECKOUT_ENDPOINT=
# Fallback checkout URL used when CAKTO_CREATE_CHECKOUT_ENDPOINT is not set.
CAKTO_CHECKOUT_URL=
# Optional overrides for the URLs sent to Cakto. Default to APP_URL/APP_PUBLIC_URL + path.
CAKTO_SUCCESS_URL=
CAKTO_CANCEL_URL=
CAKTO_WEBHOOK_URL=
# Secret/token used to validate incoming Cakto webhook requests.
CAKTO_WEBHOOK_SECRET=
CAKTO_WEBHOOK_TOKEN=

# App URL used by the Cakto integration to build absolute URLs.
# Falls back to APP_PUBLIC_URL if not set. Set both to the same value in production.
APP_URL=
